		"build": "npm run compile && ts-node ./build/packaged.ts"
	},
	"dependencies": {
		"lodash": "^4.17.21",
		"svg-path-bbox": "^2.1.0",
		"svgpath": "^2.6.0",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.2.21",
		"@types/fs-extra": "^11.0.4",
		"@types/lodash": "^4.17.14",
		"@types/node": "^22.10.2",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jszip": "^3.10.1",
		"lint-staged": "^16.2.3",
		"rimraf": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
