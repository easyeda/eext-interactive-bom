	"license": "Apache-2.0",
	"homepage": "https://github.com/easyeda/eext-interative-bom",
	"repository": {
		"type": "git",
		"url": "https://github.com/easyeda/eext-interative-bom.git"
	},
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"compile": "rimraf ./dist/ && ts-node ./config/esbuild.prod.ts",
